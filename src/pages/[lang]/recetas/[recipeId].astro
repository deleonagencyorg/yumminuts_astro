---
// src/pages/[lang]/recetas/[recipeId].astro
import { setLocale, type Locale } from '../../../i18n/i18n';
import MainLayout from '../../../layouts/MainLayout.astro';
import RecipeDetail from '../../../views/Recipes/Detail/index.astro';
import { getAllRecipes } from '../../../services/api/recipes';

export async function getStaticPaths() {
  console.log('[getStaticPaths] Generando rutas estáticas para recetas...');

  // Fetch paralelo para ambos idiomas (buena práctica)
  const [recipesEs, recipesEn] = await Promise.all([
    getAllRecipes('es'),
    getAllRecipes('en'),
  ]);

  console.log(`[getStaticPaths] Recetas ES: ${recipesEs.length} | EN: ${recipesEn.length}`);

  // Generación de rutas de forma inmutable
  const paths = [...recipesEs.map((recipe) => ({
      params: { 
        lang: 'es' as const, 
        recipeId: recipe.slug || recipe.id 
      },
      props: { 
        recipe, 
        currentLang: 'es' as const 
      },
    })),
    ...recipesEn.map((recipe) => ({
      params: { 
        lang: 'en' as const, 
        recipeId: recipe.slug || recipe.id 
      },
      props: { 
        recipe, 
        currentLang: 'en' as const 
      },
    })),
  ];

  console.log(`[getStaticPaths] Total de rutas generadas: ${paths.length}`);
  
  return paths;
}

// Props recibidos desde getStaticPaths
const { recipe, currentLang } = Astro.props;
const { lang, recipeId } = Astro.params;

setLocale(lang as Locale);

if (!recipe) {
  console.warn(`Receta no encontrada para slug: ${recipeId}`);
}
---

<MainLayout title={recipe?.title || 'Receta no encontrada'}>
  <RecipeDetail 
    currentLang={currentLang}
    recipeId={recipeId}
    recipe={recipe} 
  />
</MainLayout>