---
// src/pages/[lang]/recetas/[recipeId].astro
import { t, setLocale, type Locale } from '../../../i18n/i18n';
import MainLayout from '../../../layouts/MainLayout.astro';
import RecipeDetail from '../../../views/Recipes/Detail/index.astro';
import { getAllRecipes } from '../../../services/api/recipes';

export async function getStaticPaths() {
  const recipes = await getAllRecipes('es');
  
  console.log('Total recetas:', recipes.length);
  console.log('Slugs:', recipes.map(r => r.slug));
  
  return recipes.map((recipe) => ({
    params: { lang: 'es', recipeId: recipe.slug || recipe.id },
    props: { recipe, currentLang: 'es' }
  }));
}

const { recipe, currentLang } = Astro.props;
const { lang, recipeId } = Astro.params;

console.log('recipeId en params:', recipeId);
console.log('recipe en props:', recipe?.title);

setLocale(lang as Locale);
---

<MainLayout title={recipe?.title || 'Receta'}>
  <RecipeDetail currentLang={currentLang} recipeId={recipeId} recipe={recipe} />
</MainLayout>
