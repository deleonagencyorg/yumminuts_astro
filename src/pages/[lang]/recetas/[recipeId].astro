---
// src/pages/[lang]/recetas/[recipeId].astro
import { setLocale, type Locale } from '../../../i18n/i18n';
import MainLayout from '../../../layouts/MainLayout.astro';
import RecipeDetail from '../../../views/Recipes/Detail/index.astro';
import { getAllRecipes } from '../../../services/api/recipes';
import { config } from '../../../i18n/config';
import SEO from '../../../components/SEO.astro';

export async function getStaticPaths() {
  const locales = config.supportedLocales as Locale[];

  const allRecipesByLang = await Promise.all(
    locales.map(lang => getAllRecipes(lang))
  );

  const paths = locales.flatMap((locale, index) => 
    allRecipesByLang[index].map((recipe) => ({
      params: { lang: locale, recipeId: recipe.slug 
      },
      props: { recipe, currentLang: locale 
      }
    }))
  );
  return paths;
}

const { recipe, currentLang } = Astro.props;
const { lang, recipeId } = Astro.params;

setLocale(lang as Locale);

---
<MainLayout title={recipe?.title || 'Receta'}>
  <Fragment slot="head">
    <SEO
      currentLang={currentLang}
      title={recipe?.title}
      description={recipe?.description || recipe?.title}
      canonicalUrl={`https://snacksyummies.com/${currentLang}/recetas/${recipeId}`}
      imageUrl={typeof recipe?.image === 'string'
        ? recipe.image
        : recipe?.image?.url ?? 'https://snack.yummiespromociones.com/snacksyummies/yumminuts-receta.webp'}
    />
  </Fragment>
  <RecipeDetail currentLang={currentLang} recipeId={recipeId} recipe={recipe} 
  />
</MainLayout>