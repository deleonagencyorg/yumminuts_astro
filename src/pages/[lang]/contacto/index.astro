---
// src/pages/[lang]/contacto/index.astro
import MainLayout from '../../../layouts/MainLayout.astro';
import SEO from '../../../components/SEO.astro';
import ContactView from '../../../views/Contact/index.astro';
import { type Locale } from '../../../i18n/i18n';
import { getHeaderColors } from '../../../config/headerColors';
import { config } from '../../../i18n/config';
import { getPageBySlug } from '../../../services/api/pages';

export async function getStaticPaths() {
  return config.supportedLocales.map((locale) => ({
    params: { lang: locale },
    props: { currentLang: locale as Locale }
  }));
}

const { currentLang } = Astro.props;
const { lang } = Astro.params;

// Set header color config for contact page
const headerColorConfig = getHeaderColors('contact');
const page = await getPageBySlug('contacto', currentLang);

const pageTitle = page?.metaTitle || page?.title || (currentLang === 'es' ? 'Contacto - Yummi Nuts' : 'Contact - Yummi Nuts');
const pageDescription = page?.metaDescription || page?.excerpt || '';
const pageImage = typeof page?.ogImage === 'string'
  ? page.ogImage
  : page?.ogImage?.url ?? '';
---

<MainLayout title={pageTitle}>
  <Fragment slot="head">
    <SEO
      currentLang={currentLang}
      title={page?.ogTitle || pageTitle}
      description={page?.ogDescription || pageDescription}
      canonicalUrl={`https://snacksyummies.com/${currentLang}/${currentLang === 'es' ? 'contacto' : 'contact'}`}
      imageUrl={pageImage}
    />
  </Fragment>
  <ContactView currentLang={currentLang} headerColorConfig={headerColorConfig} />
</MainLayout>